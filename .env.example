# Flask Secret Key (change this to a random string in production)
SECRET_KEY=change-me-to-a-random-secret-key

# Optional: Override default port (default: 7860)
# PORT=7860

# Google Gemini API Key
# Get yours at https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Legacy/Paid illustrations)
# Get yours at https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face Access Token (Free/Reliable images)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=your_hugging_face_token_here
